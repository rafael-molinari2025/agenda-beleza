{
  "hosting": {
    "site": "bella-agenda-226f0",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      "firestore.rules",
      "agenda-beleza.html",
      "*.bat",
      "*.sh",
      "*.ps1",
      "README.md",
      ".git/**",
      ".claude/**",
      "node_modules/**"
    ],
    "rewrites": [
      { "source": "/app", "destination": "/app.html" },
      { "source": "/manual", "destination": "/manual.html" },
      { "source": "/admin", "destination": "/admin.html" }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
